# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# logs
**/*.log
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
perf-test/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# personal profile (use profile.example.yml as template)
content/profile.yml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# certificates & keys
*.key
*.p12
*.pfx
*.crt

# cloud credentials
credentials.json
service-account.json
.aws/
.gcp/

# database files
*.sqlite
*.sqlite3
*.db

# npm auth
.npmrc

# AI Agents
.serena/
.sisyphus/
.gemini/
.agent/
.cursor/
